---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides');
const guideLinks = [...guides].sort((a, b) => a.data.title.localeCompare(b.data.title));

const updates = await getCollection('updates', ({ data }) => !data.draft);
const recentUpdates = [...updates]
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<BaseLayout title="Understand modern slavery">
	<section class="hero">
		<h1>Understand modern slavery</h1>
		<p class="lede">
			A 2026 <a href="https://www.cnn.com/world/myfreedomday">#MyFreedomDay</a> project. Built by
			<a href="https://github.com/bobbyhuang-dev">Bobby Huang</a> and Jacky Zeng from Basis Park Lane Harbour.
		</p>
		<p>
			This website aims to inform people and raise awareness about <strong>modern slavery</strong>, a key subject in
			#MyFreedomDay, and something that needs to be end.
		</p>
	</section>

	<h2 class="section-title">Guides</h2>
	<ul class="card-grid">
		{
			guideLinks.map((g) => (
				<li class="card">
					<h2>
						<a href={`/guides/${g.id}`}>{g.data.title}</a>
					</h2>
					<p>{g.data.description}</p>
				</li>
			))
		}
	</ul>

	<h2 class="section-title">Recent updates</h2>
	{
		recentUpdates.length === 0 ? (
			<p class="muted">No updates yet.</p>
		) : (
			<ul class="card-grid">
				{recentUpdates.map((u) => (
					<li class="card">
						<p class="meta">
							<time datetime={u.data.pubDate.toISOString()}>
								{u.data.pubDate.toLocaleDateString('en-US', {
									year: 'numeric',
									month: 'short',
									day: 'numeric',
								})}
							</time>
						</p>
						<h2>
							<a href={`/updates/${u.id}`}>{u.data.title}</a>
						</h2>
						<p>{u.data.description}</p>
					</li>
				))}
			</ul>
		)
	}

	<p class="muted" style="margin-top: 2.5rem;">
		Edit Markdown in <code>src/content/</code>, run <code>pnpm dev</code> locally, and publish with your usual Git workflow.
	</p>
</BaseLayout>
