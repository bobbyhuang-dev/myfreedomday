---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('updates', ({ data }) => !data.draft);
const posts = [...all].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Updates" description="Chronological list of sample announcements and notes.">
	<article class="prose">
		<h1>Updates</h1>
		<p class="muted">Dummy posts with dates—swap for real news when you are ready.</p>
		<ul style="list-style: none; padding: 0; margin: 2rem 0 0;">
			{
				posts.map((post) => (
					<li
						style="padding: 1rem 0; border-bottom: 1px solid var(--border);"
					>
						<p class="meta" style="margin-bottom: 0.35rem;">
							<time datetime={post.data.pubDate.toISOString()}>
								{post.data.pubDate.toLocaleDateString('en-US', {
									year: 'numeric',
									month: 'long',
									day: 'numeric',
								})}
							</time>
						</p>
						<h2 style="font-size: 1.2rem; margin: 0 0 0.35rem;">
							<a href={`/updates/${post.id}`}>{post.data.title}</a>
						</h2>
						<p style="margin: 0; color: var(--muted); font-size: 0.95rem;">{post.data.description}</p>
					</li>
				))
			}
		</ul>
	</article>
</BaseLayout>
