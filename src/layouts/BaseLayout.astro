---
interface Props {
	title: string;
	description?: string;
}

const { title, description = 'Informational site focused on raising awareness about modern slavery.' } = Astro.props;
const siteName = 'Understand modern slavery';
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{fullTitle}</title>
	</head>
	<body>
		<a class="skip" href="#main">Skip to content</a>
		<header class="site-header">
			<div class="inner">
				<a class="brand" href="/">Understand modern slavery</a>
				<nav aria-label="Primary">
					<ul>
						<li><a href="/">Home</a></li>
						<li><a href="/guides/what-is-this">Guides</a></li>
						<li><a href="/updates">Updates</a></li>
						<li><a href="/contact">Contact</a></li>
					</ul>
				</nav>
			</div>
		</header>
		<main id="main" class="main">
			<slot />
		</main>
		<footer class="site-footer">
			<div class="inner">
				<p>
					Demo informational site — replace this footer with your org’s details, policies, and social links.
				</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--bg: #f6f7f9;
		--surface: #ffffff;
		--text: #1a1d23;
		--muted: #5c6370;
		--accent: #0d6e6e;
		--accent-hover: #0a5555;
		--border: #e2e5eb;
		--max: 42rem;
		--header-h: 3.5rem;
		font-family:
			system-ui,
			-apple-system,
			'Segoe UI',
			Roboto,
			'Helvetica Neue',
			Arial,
			sans-serif;
		line-height: 1.6;
		color: var(--text);
		background: var(--bg);
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	a {
		color: var(--accent);
		text-decoration-thickness: 1px;
		text-underline-offset: 0.2em;
	}

	a:hover {
		color: var(--accent-hover);
	}

	.skip {
		position: absolute;
		left: -9999px;
		z-index: 999;
		padding: 0.5rem 1rem;
		background: var(--surface);
		border: 1px solid var(--border);
	}

	.skip:focus {
		left: 1rem;
		top: 1rem;
	}

	.site-header {
		background: var(--surface);
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		z-index: 10;
	}

	.site-header .inner {
		max-width: calc(var(--max) + 4rem);
		margin: 0 auto;
		padding: 0.75rem 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.brand {
		font-weight: 700;
		font-size: 1.125rem;
		color: var(--text);
		text-decoration: none;
	}

	.brand:hover {
		color: var(--accent);
	}

	.site-header nav ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1.25rem;
	}

	.site-header nav a {
		font-weight: 500;
		color: var(--muted);
		text-decoration: none;
	}

	.site-header nav a:hover {
		color: var(--accent);
	}

	.main {
		flex: 1;
		width: 100%;
		max-width: calc(var(--max) + 4rem);
		margin: 0 auto;
		padding: 2rem 1.25rem 3rem;
	}

	.site-footer {
		border-top: 1px solid var(--border);
		background: var(--surface);
	}

	.site-footer .inner {
		max-width: calc(var(--max) + 4rem);
		margin: 0 auto;
		padding: 1.5rem 1.25rem;
	}

	.site-footer p {
		margin: 0;
		font-size: 0.9rem;
		color: var(--muted);
	}

	.prose {
		max-width: var(--max);
	}

	.prose h1 {
		font-size: 2rem;
		line-height: 1.2;
		margin: 0 0 0.75rem;
		font-weight: 700;
	}

	.prose h2 {
		font-size: 1.35rem;
		margin: 2rem 0 0.75rem;
		font-weight: 650;
	}

	.prose h3 {
		font-size: 1.1rem;
		margin: 1.5rem 0 0.5rem;
		font-weight: 600;
	}

	.prose p {
		margin: 0 0 1rem;
		color: var(--text);
	}

	.prose ul {
		margin: 0 0 1rem;
		padding-left: 1.25rem;
	}

	.prose li {
		margin-bottom: 0.35rem;
	}

	.prose strong {
		font-weight: 650;
	}

	.hero {
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--border);
		margin-bottom: 2rem;
	}

	.hero h1 {
		font-size: clamp(1.75rem, 4vw, 2.25rem);
		margin: 0 0 0.75rem;
		line-height: 1.15;
	}

	.hero .lede {
		font-size: 1.125rem;
		color: var(--muted);
		margin: 0;
		max-width: 36rem;
	}

	.card-grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.card {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 0.5rem;
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.card h2 {
		font-size: 1.05rem;
		margin: 0;
		font-weight: 650;
	}

	.card h2 a {
		color: var(--text);
		text-decoration: none;
	}

	.card h2 a:hover {
		color: var(--accent);
	}

	.card p {
		margin: 0;
		font-size: 0.95rem;
		color: var(--muted);
		flex: 1;
	}

	.meta {
		font-size: 0.85rem;
		color: var(--muted);
	}

	.section-title {
		font-size: 1.25rem;
		margin: 2.5rem 0 1rem;
		font-weight: 650;
	}

	.muted {
		color: var(--muted);
	}
</style>
