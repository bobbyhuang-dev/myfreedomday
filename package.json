{
	"name": "myfreedomday",
	"type": "module",
	"version": "0.0.1",
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"pages:deploy": "astro build && wrangler pages deploy dist",
		"pages:upload": "wrangler pages deploy dist",
		"pages:noop": "node -e \"process.exit(0)\"",
		"pages:dev": "pnpm build && wrangler pages dev ./dist",
		"astro": "astro"
	},
	"dependencies": {
		"astro": "^6.1.4"
	},
	"devDependencies": {
		"wrangler": "^4.81.0"
	}
}
